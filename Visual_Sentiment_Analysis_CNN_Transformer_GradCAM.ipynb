# Visual Sentiment Analysis with CNN-Transformer and Grad-CAM

In this notebook, we will implement a hybrid model combining CNN and Transformer for sentiment analysis on images using Google Colab with TensorFlow/Keras, along with Grad-CAM for visualization. This task involves three sentiment classes: positif, negatif, and netral.

## Import Libraries
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import tensorflow as tf
from tensorflow.keras.preprocessing.image import ImageDataGenerator
from tensorflow.keras import layers, models
from tensorflow.keras.applications import EfficientNetB0
from tensorflow.keras.callbacks import EarlyStopping
from sklearn.metrics import classification_report, confusion_matrix
import cv2

## Set Constants
dataset_path = '/content/drive/MyDrive/dataset_iran_israel_lengkap'
img_height, img_width = 256, 256
epochs = 25
batch_size = 32

## Data Preprocessing
# Setup ImageDataGenerator
train_datagen = ImageDataGenerator(
    rescale=1./255,
    validation_split=0.2
)

train_generator = train_datagen.flow_from_directory(
    dataset_path,
    target_size=(img_height, img_width),
    batch_size=batch_size,
    class_mode='categorical',
    subset='training'
)

validation_generator = train_datagen.flow_from_directory(
    dataset_path,
    target_size=(img_height, img_width),
    batch_size=batch_size,
    class_mode='categorical',
    subset='validation'
)

## Build CNN-Transformer Hybrid Model
def build_model():
    base_model = EfficientNetB0(weights='imagenet', include_top=False, input_shape=(img_height, img_width, 3))
    base_model.trainable = False  # Freeze the base model
    
    model = models.Sequential([
        base_model,
        layers.GlobalAveragePooling2D(),
        layers.Dense(128, activation='relu'),
        layers.Dropout(0.5),
        layers.Dense(3, activation='softmax')  # 3 classes
    ])
    return model

model = build_model()
model.compile(optimizer='adam', loss='categorical_crossentropy', metrics=['accuracy'])

## Training the Model
early_stopping = EarlyStopping(monitor='val_loss', patience=5, restore_best_weights=True)
model.fit(
    train_generator,
    validation_data=validation_generator,
    epochs=epochs,
    callbacks=[early_stopping]
)

## Evaluate the Model
test_loss, test_accuracy = model.evaluate(validation_generator)
print(f'Test accuracy: {test_accuracy}')

# Grad-CAM Implementation
def get_gradcam_heatmap(model, img_array, class_index):
    grad_model = tf.keras.models.Model(inputs=model.inputs,
                                       outputs=[model.layers[-1].output,
                                                model.layers[-4].output])
    with tf.GradientTape() as tape:
        model_output, conv_layer_output = grad_model(tf.cast(img_array, tf.float32))
        loss = model_output[:, class_index]
    grads = tape.gradient(loss, conv_layer_output)
    pooled_grads = tf.reduce_mean(grads, axis=(0, 1))
    heatmap = tf.reduce_mean(tf.multiply(pooled_grads, conv_layer_output), axis=-1)
    heatmap = tf.keras.backend.relu(heatmap)
    heatmap /= tf.reduce_max(heatmap)
    return heatmap.numpy()

# Visualizing with Grad-CAM
def display_gradcam(heatmap, img):
    heatmap = cv2.resize(heatmap, (img.shape[1], img.shape[0]))
    heatmap = np.uint8(255 * heatmap)
    heatmap = cv2.applyColorMap(heatmap, cv2.COLORMAP_JET)
    super_imposed_img = heatmap * 0.4 + img
    plt.imshow(super_imposed_img / 255)
    plt.axis('off')
    plt.show()

